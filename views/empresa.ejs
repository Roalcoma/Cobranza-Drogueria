<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seleccionar Empresa - Cobranza ICG</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/theme.css" rel="stylesheet">
    <script src="/js/theme.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            background: var(--bg-body); font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .bg-pattern {
            position: fixed; inset: 0;
            background:
                radial-gradient(circle at 20% 40%, var(--login-bg-pattern-1) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, var(--login-bg-pattern-2) 0%, transparent 50%);
        }
        .empresa-card {
            position: relative; width: 100%; max-width: 480px;
            border-radius: 20px; overflow: hidden;
            background: var(--login-card-bg); border: 1px solid var(--login-card-border);
            backdrop-filter: blur(20px); box-shadow: var(--shadow-modal);
            animation: cardIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        @keyframes cardIn { from { opacity:0; transform: translateY(30px) scale(0.95); } to { opacity:1; transform: translateY(0) scale(1); } }
        .card-header-custom { padding: 2rem 2rem 1rem; text-align: center; }
        .card-header-custom .icon-wrap {
            width: 56px; height: 56px;
            background: linear-gradient(135deg, var(--green), var(--green-dark));
            border-radius: 16px; display: inline-flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: white; margin-bottom: 0.75rem;
            box-shadow: 0 8px 25px rgba(134,187,37,0.35);
        }
        .card-header-custom h2 { color: var(--text-primary); font-weight: 800; font-size: 1.4rem; }
        .card-header-custom p { color: var(--text-muted); font-size: 0.82rem; margin-top: 0.25rem; }
        .user-badge {
            display: inline-flex; align-items: center; gap: 0.4rem;
            background: var(--chip-green-bg); border: 1px solid rgba(134,187,37,0.2);
            border-radius: 20px; padding: 0.3rem 0.8rem;
            color: var(--chip-green-text); font-size: 0.78rem; font-weight: 600; margin-top: 0.75rem;
        }
        .empresa-list { padding: 0.5rem 1.5rem 1.5rem; max-height: 450px; overflow-y: auto; }
        .empresa-btn {
            display: flex; align-items: center; gap: 1rem; width: 100%;
            padding: 1rem 1.2rem; margin-bottom: 0.6rem;
            background: var(--empresa-btn-bg); border: 1px solid var(--empresa-btn-border);
            border-radius: 14px; color: var(--text-primary); cursor: pointer; transition: all 0.2s; text-align: left;
        }
        .empresa-btn:hover { background: rgba(134,187,37,0.1); border-color: rgba(134,187,37,0.3); transform: translateX(4px); }
        .empresa-btn .emp-icon {
            width: 42px; height: 42px; background: rgba(134,187,37,0.15); border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: var(--green); flex-shrink: 0;
        }
        .empresa-btn .emp-info h6 { margin: 0; font-weight: 700; font-size: 0.95rem; color: var(--text-primary); }
        .empresa-btn .emp-info small { color: var(--empresa-sub); font-size: 0.72rem; }
        .empresa-btn .emp-arrow { margin-left: auto; color: var(--empresa-arrow); font-size: 1.1rem; transition: all 0.2s; }
        .empresa-btn:hover .emp-arrow { color: var(--green); transform: translateX(3px); }
        .footer-links { text-align: center; padding: 0 1.5rem 1.5rem; }
        .footer-links a { color: var(--text-muted); font-size: 0.78rem; text-decoration: none; transition: color 0.2s; }
        .footer-links a:hover { color: var(--text-secondary); }
        .theme-corner { position: fixed; top: 1rem; right: 1rem; z-index: 10; }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 2px; }
    </style>
</head>
<body>
    <div class="bg-pattern"></div>
    <div class="theme-corner">
        <button class="btn-theme" onclick="toggleTheme()" title="Cambiar tema"><i class="bi bi-sun" id="themeIcon"></i></button>
    </div>
    <div class="empresa-card">
        <div class="card-header-custom">
            <div class="icon-wrap"><i class="bi bi-building"></i></div>
            <h2>Seleccionar Empresa</h2>
            <p>Elija la empresa con la que desea trabajar</p>
            <div class="user-badge"><i class="bi bi-person-circle"></i> <%= user.username %></div>
        </div>
        <div class="empresa-list">
            <% user.empresas.forEach(function(emp) { %>
                <form method="POST" action="/empresa" style="display:contents;">
                    <input type="hidden" name="codEmpresa" value="<%= emp.cod %>">
                    <button type="submit" class="empresa-btn">
                        <div class="emp-icon"><i class="bi bi-shop"></i></div>
                        <div class="emp-info">
                            <h6><%= emp.titulo %></h6>
                            <small><%= emp.pathBd %></small>
                        </div>
                        <i class="bi bi-chevron-right emp-arrow"></i>
                    </button>
                </form>
            <% }); %>
        </div>
        <div class="footer-links"><a href="/logout"><i class="bi bi-box-arrow-left me-1"></i>Cerrar Sesion</a></div>
    </div>
</body>
</html>
