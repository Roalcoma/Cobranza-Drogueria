<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Cobranza ICG</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/theme.css" rel="stylesheet">
    <script src="/js/theme.js"></script>
    <style>
        * { box-sizing: border-box; }
        body { min-height: 100vh; background: var(--bg-body); color: var(--text-primary); font-family: 'Segoe UI', system-ui, sans-serif; padding: 2rem 1.5rem; }
        .admin-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; }
        .admin-card h6 { font-weight: 700; margin-bottom: 0.25rem; }
        .btn-admin { border-radius: 10px; font-weight: 600; font-size: 0.85rem; padding: 0.45rem 1rem; border: none; cursor: pointer; transition: all 0.2s; }
        .btn-green { background: linear-gradient(135deg,#86BB25,#5a8018); color: #fff; }
        .btn-green:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-outline { background: rgba(134,187,37,.1); color: var(--green); border: 1px solid rgba(134,187,37,.3); }
        .btn-outline:hover { background: rgba(134,187,37,.2); }
        .btn-ghost { background: var(--bg-input); color: var(--text-muted); border: 1px solid var(--border-input); }
        .btn-ghost:hover { color: var(--text-primary); }
        .status-box { margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 10px; font-size: 0.83rem; display: none; }
        .status-ok { background: rgba(134,187,37,.12); color: var(--green); border: 1px solid rgba(134,187,37,.3); }
        .status-err { background: rgba(220,53,69,.1); color: var(--red); border: 1px solid rgba(220,53,69,.25); }
        .navbar-top { background: var(--bg-darker); border-bottom: 1px solid var(--border); padding: 0.6rem 1.5rem; margin: -2rem -1.5rem 2rem; }
    </style>
</head>
<body>
    <div class="navbar-top d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <div style="width:32px;height:32px;background:linear-gradient(135deg,#86BB25,#5a8018);border-radius:9px;display:inline-flex;align-items:center;justify-content:center;font-size:0.95rem;color:white;">
                <i class="bi bi-shield-lock"></i>
            </div>
            <span style="font-weight:800; font-size:1.05rem;">Panel Admin</span>
            <span style="color:var(--text-muted); font-size:0.8rem;">— Cobranza ICG</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn-admin btn-ghost" onclick="toggleTheme()"><i class="bi bi-sun" id="themeIcon"></i></button>
            <a href="/" class="btn-admin btn-ghost" style="text-decoration:none;"><i class="bi bi-arrow-left me-1"></i>Sistema</a>
            <a href="/admin/logout" class="btn-admin btn-ghost" style="text-decoration:none; color:var(--red);"><i class="bi bi-box-arrow-right me-1"></i>Salir</a>
        </div>
    </div>

    <div style="max-width:680px; margin:0 auto;">

        <!-- Actualización GitHub -->
        <div class="admin-card">
            <h6><i class="bi bi-cloud-download me-2" style="color:var(--green);"></i>Actualización desde GitHub</h6>
            <p style="font-size:.82rem; color:var(--text-muted); margin-bottom:1rem;">
                Descarga la última versión desde el repositorio y aplica los cambios.<br>
                <span style="color:var(--text-muted); font-size:.75rem;">No sobreescribe <code>.env</code>, <code>node_modules</code> ni <code>logs</code>.</span>
            </p>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn-admin btn-green" id="btnUpdate" onclick="actualizarDesdeGithub()">
                    <i class="bi bi-cloud-download me-1"></i>Descargar e instalar
                </button>
                <button class="btn-admin btn-outline" id="btnRestart" onclick="reiniciarServidor()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Reiniciar servidor
                </button>
            </div>
            <div id="updateStatus" class="status-box"></div>
        </div>

        <!-- SP Toggle -->
        <div class="admin-card">
            <h6><i class="bi bi-gear me-2" style="color:var(--green);"></i>Procedimiento almacenado</h6>
            <p style="font-size:.82rem; color:var(--text-muted); margin-bottom:1rem;">
                Controla si se ejecuta <code>[rip].[PROC_DEX_PROCESAR_TESORERIA]</code> al registrar un cobro.<br>
                <span style="font-size:.75rem;">Desactívalo para hacer pruebas sin procesar en contabilidad.</span>
            </p>
            <div class="d-flex align-items-center gap-3">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="spToggle" onchange="toggleSP(this)" style="width:2.5em;height:1.3em;cursor:pointer;">
                    <label class="form-check-label fw-bold" for="spToggle" id="spLabel" style="font-size:.9rem;">Cargando...</label>
                </div>
            </div>
            <div id="spStatus" class="status-box"></div>
        </div>

    </div>

    <script>
    async function actualizarDesdeGithub() {
        const btn = document.getElementById('btnUpdate');
        const st = document.getElementById('updateStatus');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;"></span>Descargando...';
        st.style.display = 'none';
        try {
            const r = await fetch('/admin/update', { method: 'POST' });
            const d = await r.json();
            st.className = 'status-box ' + (r.ok ? 'status-ok' : 'status-err');
            st.textContent = r.ok
                ? '✓ Actualización aplicada. Presiona "Reiniciar servidor" para activar los cambios.'
                : '✗ ' + d.error;
        } catch(e) {
            st.className = 'status-box status-err';
            st.textContent = '✗ ' + e.message;
        }
        st.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-cloud-download me-1"></i>Descargar e instalar';
    }

    async function reiniciarServidor() {
        const btn = document.getElementById('btnRestart');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" style="width:.8rem;height:.8rem;"></span>Reiniciando...';
        try { await fetch('/admin/restart', { method: 'POST' }); } catch(_) {}
        const st = document.getElementById('updateStatus');
        st.className = 'status-box status-ok';
        st.textContent = 'Servidor reiniciando... reconectando en segundos.';
        st.style.display = 'block';
        setTimeout(() => {
            const poll = setInterval(() => {
                fetch('/admin').then(r => { if (r.ok) { clearInterval(poll); location.reload(); } }).catch(() => {});
            }, 1000);
        }, 1500);
    }

    async function cargarEstadoSP() {
        const r = await fetch('/admin/sp-status');
        const d = await r.json();
        const chk = document.getElementById('spToggle');
        chk.checked = d.runSP;
        actualizarLabelSP(d.runSP);
    }
    function actualizarLabelSP(activo) {
        const lbl = document.getElementById('spLabel');
        lbl.textContent = activo ? 'Activado — SP se ejecuta al cobrar' : 'Desactivado — SP no se ejecuta';
        lbl.style.color = activo ? 'var(--green)' : 'var(--red)';
    }
    async function toggleSP(chk) {
        const st = document.getElementById('spStatus');
        const r = await fetch('/admin/toggle-sp', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ enabled: chk.checked }) });
        const d = await r.json();
        actualizarLabelSP(d.runSP);
        st.className = 'status-box status-ok';
        st.textContent = d.runSP ? '✓ SP activado. Los cobros procesarán en contabilidad.' : '✓ SP desactivado. Los cobros se guardan pero no se procesan.';
        st.style.display = 'block';
    }
    cargarEstadoSP();
    </script>
</body>
</html>
